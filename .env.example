# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  Copy this to .env and fill in your values
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# IBM Cloud API Key  (IAM → Manage → API keys)
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here


# Watsonx.ai Project ID  (Watsonx platform → Projects → your project → Manage)
WATSONX_PROJECT_ID=your_watsonx_project_id_here
# Watsonx.ai regional endpoint — match the region where your Watsonx instance lives
# Dallas:    https://us-south.ml.cloud.ibm.com
# Frankfurt: https://eu-de.ml.cloud.ibm.com
# Tokyo:     https://jp-tok.ml.cloud.ibm.com
# London:    https://eu-gb.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Cloud Pak for Data (CP4D) version — ONLY needed when WATSONX_URL points to a
# CP4D on-prem cluster (not required for IBM Cloud SaaS endpoints above).
# Supported values: 5.0  5.1  5.2  5.3  5.4
# WATSONX_VERSION=5.4

# Flask
FLASK_SECRET_KEY=your_random_secrete_key_here
FLASK_DEBUG=false

# Server port  (default 5000)
PORT=5000
